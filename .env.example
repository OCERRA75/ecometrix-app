# ─── EcoMetriX — Variables de entorno ────────────────────────────────────────
# Copia este archivo como .env y completa los valores reales
# NUNCA subir .env al repositorio (está en .gitignore)

# Claude API — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Resend — resend.com → API Keys
RESEND_API_KEY=re_...

# URL pública del sitio
VITE_APP_URL=https://ecometrix-co.netlify.app
